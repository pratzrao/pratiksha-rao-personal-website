---
const roomImage = "/images/pratikshas-room-concept-v1.png";
const comingSoonHotspots = [
  { id: "reading", label: "Reading", tooltip: "Reading" },
  { id: "globe", label: "The world" },
  { id: "piano", label: "Piano" },
  { id: "crochet", label: "Crochet" },
  { id: "laptop", label: "Work and resume" },
  { id: "typewriter", label: "Writing" },
  { id: "journal", label: "Journal" },
  { id: "mirror", label: "About" },
  { id: "plant", label: "The garden" },
  { id: "television", label: "Watching" },
  { id: "telephone", label: "Contact" },
  { id: "paintings", label: "Gallery" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Pratiksha's Room - a personal place for books, music, words, work, and small beautiful things."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,600&display=swap"
      rel="stylesheet"
    />
    <title>Pratiksha's Room</title>
  </head>
  <body>
    <main class="room-page">
      <div class="room-art">
        <img
          src={roomImage}
          alt="An illustrated dark-academia study with a bookcase, writing desk, piano, and cabinet of curiosities."
        />
        {
          comingSoonHotspots.map(({ id, label, tooltip = "Coming soon" }) => (
            <button
              class:list={["hotspot", "status-hotspot", `${id}-hotspot`]}
              type="button"
              aria-label={`${label}, coming soon`}
              aria-expanded="false"
            >
              <span class="hotspot-marker" aria-hidden="true"></span>
              <span class="hotspot-tooltip" role="tooltip">{tooltip}</span>
            </button>
          ))
        }
      </div>

      <header class="site-title" aria-labelledby="page-title">
        <h1 id="page-title">Pratiksha's<br />Room</h1>
      </header>
    </main>

    <script>
      const statusHotspots = document.querySelectorAll<HTMLButtonElement>(".status-hotspot");
      const roomPage = document.querySelector<HTMLElement>(".room-page");
      const roomArt = document.querySelector<HTMLElement>(".room-art");

      statusHotspots.forEach((hotspot) => {
        hotspot.addEventListener("click", () => {
          const isExpanded = hotspot.getAttribute("aria-expanded") === "true";

          statusHotspots.forEach((otherHotspot) => {
            otherHotspot.setAttribute("aria-expanded", "false");
          });

          hotspot.setAttribute("aria-expanded", String(!isExpanded));
        });
      });

      if (roomPage && roomArt) {
        const mobileRoom = window.matchMedia("(max-width: 700px)");
        let panX = 0;
        let panY = 0;
        let pointerId: number | null = null;
        let startX = 0;
        let startY = 0;
        let startPanX = 0;
        let startPanY = 0;
        let previousMobileMode = mobileRoom.matches;

        const clamp = (value: number, minimum: number, maximum: number) =>
          Math.min(Math.max(value, minimum), maximum);

        const getBounds = () => ({
          x: Math.max(0, (roomArt.offsetWidth - roomPage.clientWidth) / 2),
          y: Math.max(0, (roomArt.offsetHeight - roomPage.clientHeight) / 2),
        });

        const renderPan = () => {
          roomArt.style.setProperty("--pan-x", `${panX}px`);
          roomArt.style.setProperty("--pan-y", `${panY}px`);
        };

        const setInitialPan = () => {
          const bounds = getBounds();
          panX = mobileRoom.matches ? Math.max(-bounds.x, -roomArt.offsetWidth * 0.13) : 0;
          panY = 0;
          renderPan();
        };

        const keepPanInBounds = () => {
          const bounds = getBounds();
          panX = clamp(panX, -bounds.x, bounds.x);
          panY = clamp(panY, -bounds.y, bounds.y);
          renderPan();
        };

        requestAnimationFrame(setInitialPan);

        window.addEventListener("resize", () => {
          if (mobileRoom.matches !== previousMobileMode) {
            previousMobileMode = mobileRoom.matches;
            setInitialPan();
          } else {
            keepPanInBounds();
          }
        });

        roomPage.addEventListener("pointerdown", (event: PointerEvent) => {
          if (event.target instanceof Element && event.target.closest(".hotspot")) return;

          statusHotspots.forEach((hotspot) => {
            hotspot.setAttribute("aria-expanded", "false");
          });

          pointerId = event.pointerId;
          startX = event.clientX;
          startY = event.clientY;
          startPanX = panX;
          startPanY = panY;
          roomPage.dataset.dragging = "true";
          roomPage.setPointerCapture(pointerId);
        });

        roomPage.addEventListener("pointermove", (event: PointerEvent) => {
          if (event.pointerId !== pointerId) return;

          const bounds = getBounds();
          panX = clamp(startPanX + event.clientX - startX, -bounds.x, bounds.x);
          panY = clamp(startPanY + event.clientY - startY, -bounds.y, bounds.y);
          renderPan();
        });

        const stopDragging = (event: PointerEvent) => {
          if (event.pointerId !== pointerId) return;

          roomPage.releasePointerCapture(pointerId);
          pointerId = null;
          delete roomPage.dataset.dragging;
        };

        roomPage.addEventListener("pointerup", stopDragging);
        roomPage.addEventListener("pointercancel", stopDragging);
      }
    </script>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    background: #100e0d;
    color: #f0e4d0;
    font-family: Georgia, "Times New Roman", serif;
    min-height: 100%;
  }

  :global(body) {
    margin: 0;
    min-height: 100%;
  }

  .room-page {
    background: #100e0d;
    isolation: isolate;
    min-height: 100svh;
    overflow: hidden;
    position: relative;
    touch-action: none;
  }

  .room-page::after {
    background:
      linear-gradient(90deg, rgba(9, 8, 8, 0.76) 0%, rgba(9, 8, 8, 0.42) 24%, transparent 47%),
      linear-gradient(180deg, rgba(8, 7, 7, 0.42) 0%, transparent 34%);
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 1;
  }

  .room-art {
    --pan-x: 0px;
    --pan-y: 0px;
    aspect-ratio: 1672 / 941;
    cursor: grab;
    height: auto;
    left: 50%;
    min-width: 100vw;
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%) translate(var(--pan-x), var(--pan-y));
    transition: transform 260ms ease-out;
    user-select: none;
    width: 177.68svh;
  }

  .room-art > img {
    display: block;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    width: 100%;
  }

  .site-title {
    left: clamp(1.4rem, 4vw, 4.5rem);
    max-width: 24rem;
    pointer-events: none;
    position: absolute;
    top: clamp(1.4rem, 4vw, 4.25rem);
    z-index: 2;
  }

  h1,
  .hotspot-tooltip {
    font-family: "Cormorant Garamond", Garamond, Georgia, serif;
    letter-spacing: 0;
  }

  h1 {
    color: #f0e4d0;
    font-size: 5.5rem;
    font-weight: 600;
    line-height: 0.82;
    margin: 0;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.72);
  }

  .hotspot {
    appearance: none;
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 0;
    position: absolute;
    z-index: 1;
  }

  .reading-hotspot {
    --marker-x: 51%;
    --marker-y: 52%;
    height: 58%;
    left: 59.5%;
    top: 6%;
    width: 16.7%;
  }

  .globe-hotspot {
    --marker-x: 47%;
    --marker-y: 46%;
    height: 18%;
    left: 46%;
    top: 39%;
    width: 10%;
  }

  .piano-hotspot {
    --marker-x: 45%;
    --marker-y: 57%;
    height: 32%;
    left: 26%;
    top: 27%;
    width: 18%;
  }

  .crochet-hotspot {
    --marker-x: 22%;
    --marker-y: 49%;
    height: 16%;
    left: 15%;
    top: 73%;
    width: 13%;
  }

  .laptop-hotspot {
    --marker-x: 45%;
    --marker-y: 47%;
    height: 15%;
    left: 62%;
    top: 55%;
    width: 11%;
    z-index: 2;
  }

  .typewriter-hotspot {
    --marker-x: 47%;
    --marker-y: 64%;
    height: 18%;
    left: 44%;
    top: 49%;
    width: 12%;
  }

  .journal-hotspot {
    --marker-x: 48%;
    --marker-y: 49%;
    height: 12%;
    left: var(--marker-x, 52%);
    top: 61%;
    width: 10%;
  }

  .mirror-hotspot {
    --marker-x: 37%;
    --marker-y: 54%;
    height: 51%;
    left: 3%;
    top: 29%;
    width: 9%;
  }

  .plant-hotspot {
    --marker-x: 40%;
    --marker-y: 55%;
    height: 24%;
    left: 10%;
    top: 34%;
    width: 10%;
  }

  .television-hotspot {
    --marker-x: 50%;
    --marker-y: 57%;
    height: 19%;
    left: 86%;
    top: 37%;
    width: 13%;
  }

  .telephone-hotspot {
    --marker-x: 48%;
    --marker-y: 67%;
    height: 15%;
    left: 71%;
    top: 58%;
    width: 12%;
    z-index: 2;
  }

  .paintings-hotspot {
    --marker-x: 49%;
    --marker-y: 55%;
    height: 17%;
    left: 30%;
    top: 16%;
    width: 13%;
  }

  .hotspot::before {
    background: radial-gradient(ellipse at center, rgba(224, 181, 91, 0.2), rgba(224, 181, 91, 0.05) 46%, transparent 72%);
    content: "";
    inset: -6%;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transition: opacity 180ms ease;
  }

  .hotspot-marker {
    background: #d7aa56;
    border: 1px solid rgba(255, 235, 191, 0.92);
    border-radius: 50%;
    box-shadow: 0 0 0 5px rgba(215, 170, 86, 0.13), 0 0 16px rgba(231, 181, 77, 0.82);
    height: 0.7rem;
    left: 52%;
    position: absolute;
    top: var(--marker-y, 47%);
    transform: translate(-50%, -50%);
    transition: box-shadow 180ms ease, transform 180ms ease;
    width: 0.7rem;
  }

  .hotspot-marker::after {
    border: 1px solid rgba(235, 197, 113, 0.58);
    border-radius: 50%;
    content: "";
    inset: -0.34rem;
    position: absolute;
  }

  .hotspot-tooltip {
    background: rgba(20, 16, 13, 0.9);
    border: 1px solid rgba(215, 170, 86, 0.62);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.32);
    color: #f5e4c6;
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 600;
    left: var(--marker-x, 52%);
    line-height: 1;
    opacity: 0;
    padding: 0.62rem 0.95rem 0.68rem;
    pointer-events: none;
    position: absolute;
    top: var(--marker-y, 47%);
    transform: translate(-50%, calc(-100% - 1rem)) translateY(0.3rem);
    transition: opacity 180ms ease, transform 180ms ease;
    white-space: nowrap;
  }

  .hotspot:hover::before,
  .hotspot:focus-visible::before,
  .hotspot[aria-expanded="true"]::before {
    opacity: 1;
  }

  .hotspot:hover .hotspot-marker,
  .hotspot:focus-visible .hotspot-marker,
  .hotspot[aria-expanded="true"] .hotspot-marker {
    box-shadow: 0 0 0 8px rgba(215, 170, 86, 0.2), 0 0 23px rgba(242, 197, 101, 0.95);
    transform: translate(-50%, -50%) scale(1.18);
  }

  .hotspot:hover .hotspot-tooltip,
  .hotspot:focus-visible .hotspot-tooltip,
  .hotspot[aria-expanded="true"] .hotspot-tooltip {
    opacity: 1;
    transform: translate(-50%, calc(-100% - 1rem));
  }

  .hotspot:focus-visible {
    outline: 2px solid #f5dfad;
    outline-offset: 4px;
  }

  .room-page[data-dragging="true"] .room-art {
    cursor: grabbing;
    transition: none;
  }

  @media (max-width: 1000px) {
    .site-title {
      max-width: 18rem;
    }

    h1 {
      font-size: 4.5rem;
    }
  }

  @media (max-width: 700px) {

    .site-title {
      max-width: 11rem;
      top: 1.25rem;
    }

    h1 {
      font-size: 3.4rem;
    }

    .reading-hotspot {
      height: 63%;
      left: 59%;
      top: 4%;
      width: 18%;
    }

    .hotspot-tooltip {
      font-size: 1.25rem;
    }
  }

  @media (max-width: 430px) {
    .site-title {
      left: 1.2rem;
      max-width: 9rem;
    }

    h1 {
      font-size: 2.8rem;
    }
  }

  @media (max-height: 700px) and (min-width: 701px) {
    .site-title {
      top: 1.8rem;
    }

    h1 {
      font-size: 4.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hotspot::before,
    .hotspot-marker,
    .hotspot-tooltip {
      transition: none;
    }
  }
</style>
